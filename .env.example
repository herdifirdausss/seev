# Copy to .env for local infrastructure defaults. Docker Compose supplies
# each application container's service-specific values explicitly; when a
# binary is run from the host, export the matching section below.

# ── Shared infrastructure ───────────────────────────────────────────────────
APP_ENV=development
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=seev_app
POSTGRES_PASSWORD=seev_app
POSTGRES_DB=seev
POSTGRES_SSL_MODE=disable
POSTGRES_MIGRATE_USER=seev
POSTGRES_MIGRATE_PASSWORD=seev
POSTGRES_MAX_OPEN_CONNS=10
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=5m
POSTGRES_CONN_MAX_IDLE_TIME=5m
POSTGRES_STATEMENT_TIMEOUT=5s
POSTGRES_LOCK_TIMEOUT=2s
POSTGRES_IDLE_IN_TX_TIMEOUT=10s

# Host processes use the published Compose port 6380. Containers use
# redis:6379, as set in docker-compose.yml.
REDIS_ENABLED=true
REDIS_ADDR=localhost:6380
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5
REDIS_POOL_TIMEOUT=4s

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=seev
RABBITMQ_PASSWORD=seev
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=ledger.events
RABBITMQ_RECONNECT_DELAY=5s
RABBITMQ_MAX_RECONNECT_ATTEMPTS=10
RABBITMQ_CHANNEL_POOL_SIZE=16
RABBITMQ_MAX_CONCURRENT_PUBLISH=64
RABBITMQ_DRAIN_TIMEOUT=30s
RABBITMQ_DIAL_TIMEOUT=10s
RABBITMQ_PUBLISH_TIMEOUT=5s
RABBITMQ_APP_ID=seev
RABBITMQ_TLS=

# These values must match across all services.
JWT_SECRET=change-me-to-a-random-32-plus-character-secret
JWT_ACCESS_EXPIRY=5m
JWT_REFRESH_EXPIRY=168h
# docs/plan/49 TM-07: every service now REFUSES to boot if this is empty
# (internal/config validate()) — issuer validation used to be silently
# skippable by leaving this blank, so it can no longer be left empty.
JWT_ISSUER=seev
# docs/plan/49 K5: every gRPC server now REFUSES to boot if this is empty
# (pkg/grpcx.NewServer fails fast) — the old behavior of silently accepting
# every call when unset is gone, so this can no longer be left blank.
INTERNAL_GRPC_TOKEN=change-me-to-a-random-32-plus-character-token
# docs/plan/49 K3: directory containing ca.pem plus one <service>.pem/
# <service>-key.pem pair per identity, written by `make certs`
# (cmd/certgen) — every service loads its own pair plus the shared CA from
# here via pkg/tlsx for mTLS between services.
TLS_CERT_DIR=deploy/certs
# docs/plan/49 K7: optional. When BOTH are set, internal/config overlays
# every getenv() read with a matching key from Vault's KV v2 engine at
# secret/<APP_NAME> — Vault wins over env for any key it has; anything
# Vault doesn't have falls through to env unchanged. Leave both unset (the
# default, and the only path CI/nightly ever exercise) for today's
# plain-env behavior with zero Vault dependency. To try it locally:
#   docker compose --profile secrets up -d vault
#   ./scripts/vault-seed.sh
#   export VAULT_ADDR=http://localhost:18200 VAULT_TOKEN=seev-dev-root-token
# VAULT_ADDR=
# VAULT_TOKEN=
LOG_LEVEL=info
LOG_FORMAT=json

# ── gateway (`go run ./cmd/gateway`) ────────────────────────────────────────
# Public :8080, internal health/metrics :8081, DB seev_gateway. The gateway
# owns internal/handler + internal/notify and consumes ledger events.
# APP_NAME=gateway-service
# APP_PORT=8080
# INTERNAL_APP_PORT=8081
# INTERNAL_APP_BIND_ADDR=127.0.0.1
# POSTGRES_USER=gateway_app
# POSTGRES_PASSWORD=gateway_app
# POSTGRES_DB=seev_gateway
# LEDGER_GRPC_ADDR=localhost:9091
# LEDGER_USER_API_URL=https://localhost:8090
# PAYIN_GRPC_ADDR=localhost:9092
# PAYOUT_GRPC_ADDR=localhost:9093

# ── auth-service (`go run ./cmd/auth-service`) ──────────────────────────────
# Public auth/profile :8082; internal health/metrics :8083.
# APP_NAME=auth-service
# APP_PORT=8082
# INTERNAL_APP_PORT=8083
# POSTGRES_USER=auth_app
# POSTGRES_PASSWORD=auth_app
# POSTGRES_DB=seev_auth
# LEDGER_GRPC_ADDR=localhost:9091
# AUTH_BOOTSTRAP_ADMIN_EMAIL=
# AUTH_BOOTSTRAP_ADMIN_PASSWORD=
# AUTH_BOOTSTRAP_MAKER_EMAIL=
# AUTH_BOOTSTRAP_MAKER_PASSWORD=
# AUTH_BOOTSTRAP_CHECKER_EMAIL=
# AUTH_BOOTSTRAP_CHECKER_PASSWORD=
# KYC_PROVIDER_URL= (optional HTTP sandbox/production adapter; empty = mockkyc)
# KYC_PROVIDER_TOKEN= (optional; never commit or log)
# KYC_PROVIDER_NAME=http-kyc
# KYC_RESCREEN_INTERVAL=24h
# KYC_DOC_KEK=32-byte-secret-change-me (optional; upload returns 503 when absent)

# ── admin-bff-service (`go run ./cmd/admin-bff-service`) ────────────────────
# Internal operator console :8095; database seev_adminbff.
# APP_NAME=admin-bff-service
# APP_PORT=8095
# POSTGRES_USER=adminbff_app
# POSTGRES_PASSWORD=adminbff_app
# POSTGRES_DB=seev_adminbff
# AUTH_SERVICE_URL targets auth's PUBLIC login endpoint and stays plain
# (docs/plan/49 anti-scope edge exception); every other target below is
# genuinely internal and requires https (K6).
# AUTH_SERVICE_URL=http://localhost:8082
# AUTH_ADMIN_SERVICE_URL=https://localhost:8083
# LEDGER_SERVICE_URL=https://localhost:8091
# PAYIN_SERVICE_URL=https://localhost:8092
# PAYOUT_SERVICE_URL=https://localhost:8093
# FRAUD_SERVICE_URL=https://localhost:8094
# GATEWAY_SERVICE_URL=https://localhost:8081
# ADMIN_BFF_SECURE_COOKIE=false

# ── assurance-service (`go run ./cmd/assurance-service`) ───────────────────
# Read-only cross-service reconciliation :18096 for host-binary mode
# (container port :8096 in Compose); database seev_assurance.
# APP_NAME=assurance-service
# APP_PORT=18096
# POSTGRES_USER=assurance_app
# POSTGRES_PASSWORD=assurance_app
# POSTGRES_DB=seev_assurance
# PAYIN_GRPC_ADDR=localhost:9092
# PAYOUT_GRPC_ADDR=localhost:9093
# LEDGER_GRPC_ADDR=localhost:9091
# ASSURANCE_INTERVAL=60s
# ASSURANCE_CONSISTENCY_DELAY=2m
# ASSURANCE_PAGE_SIZE=500
# ASSURANCE_RPC_TIMEOUT=3s
# ASSURANCE_CONCURRENCY=2
# ALERT_WEBHOOK_URL=

# ── ledger-service (`go run ./cmd/ledger-service`) ──────────────────────────
# User HTTP :8090; internal HTTP :8091; gRPC :9091.
# APP_NAME=ledger-service
# APP_PORT=8090
# INTERNAL_APP_PORT=8091
# GRPC_PORT=9091
# POSTGRES_USER=ledger_app
# POSTGRES_PASSWORD=ledger_app
# POSTGRES_DB=seev_ledger
# FRAUD_GRPC_ADDR=localhost:9094
# WORKER_ENABLED=true
# OUTBOX_POLL_INTERVAL=1s
# OUTBOX_BATCH_SIZE=100
# ALERT_WEBHOOK_URL=
# LEDGER_MAX_AMOUNT_PER_TX=1000000000
# OTEL_EXPORTER_OTLP_ENDPOINT=
# FEE_QUOTE_TTL=10m

# ── payin-service (`go run ./cmd/payin-service`) ────────────────────────────
# Admin HTTP :8092; gRPC :9092; Redis DB 0 (optional — only used by the
# opt-in distributed breaker below, docs/plan/45 Task T2).
# APP_NAME=payin-service
# APP_PORT=8092
# GRPC_PORT=9092
# POSTGRES_USER=payin_app
# POSTGRES_PASSWORD=payin_app
# POSTGRES_DB=seev_payin
# LEDGER_GRPC_ADDR=localhost:9091
# REDIS_DB=0
# TOPUP_INTENT_TTL=1h
# VENDOR_MOCKVENDOR_ENABLED=true
# VENDOR_MOCKVENDOR_SECRET=change-me-mockvendor-secret-at-least-32-chars
# MOCKVENDOR2_ENABLED=true
# MOCKVENDOR2_SECRET=change-me-mockvendor2-secret-at-least-32-chars
# FRAUD_GRPC_ADDR=localhost:9094
# BREAKER_FAILURE_THRESHOLD=5
# BREAKER_COOLDOWN=30s
# BREAKER_DISTRIBUTED=false

# ── payout-service (`go run ./cmd/payout-service`) ──────────────────────────
# Admin HTTP :8093; gRPC :9093; Redis DB 0.
# APP_NAME=payout-service
# APP_PORT=8093
# GRPC_PORT=9093
# POSTGRES_USER=payout_app
# POSTGRES_PASSWORD=payout_app
# POSTGRES_DB=seev_payout
# LEDGER_GRPC_ADDR=localhost:9091
# REDIS_DB=0
# VENDOR_MOCKVENDOR_ENABLED=true
# VENDOR_MOCKVENDOR_SECRET=change-me-mockvendor-secret-at-least-32-chars
# MOCKVENDOR2_ENABLED=true
# MOCKVENDOR2_SECRET=change-me-mockvendor2-secret-at-least-32-chars
# FRAUD_GRPC_ADDR=localhost:9094
# BREAKER_FAILURE_THRESHOLD=5
# BREAKER_COOLDOWN=30s
# BREAKER_DISTRIBUTED=false

# ── fraud-service (`go run ./cmd/fraud-service`) ────────────────────────────
# Admin HTTP :8094; gRPC :9094; Redis DB 1; consumes ledger events.
# APP_NAME=fraud-service
# APP_PORT=8094
# GRPC_PORT=9094
# POSTGRES_USER=fraud_app
# POSTGRES_PASSWORD=fraud_app
# POSTGRES_DB=seev_fraud
# REDIS_DB=1
# SCREENING_MODE=off
# SCREENING_AMOUNT_THRESHOLD=0
# SCREENING_VELOCITY_MAX_PER_HOUR=0

# ── Shared HTTP behavior ────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
APP_READ_TIMEOUT=15s
APP_WRITE_TIMEOUT=15s
APP_IDLE_TIMEOUT=60s
APP_SHUTDOWN_TIMEOUT=30s
TRUST_PROXY_HEADERS=false
# CORS_ALLOWED_ORIGINS: comma-separated browser origins allowed to call
# gateway/auth-service directly (e.g. https://app.example.com,https://admin.example.com).
# Unset by default — this API is bearer-token only (no cookies), so an empty
# allowlist ("no browser origin allowed") is the correct default rather than
# a wildcard (docs/plan/49 TM-06). Only used outside production; production
# always pins CORS to APP_BASE_URL.
# CORS_ALLOWED_ORIGINS=
