# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Build output (`make build`) and stray extensionless binaries from
# `go build ./cmd/<pkg>` run without -o at the repo root (easy to do by
# accident — happened once building cmd/gentoken).
/bin/
/server
/gentoken
/gateway
/payout-service

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Local secrets generated by `make observability-secret` (docs/plan/43 K1) —
# never committed; regenerated per machine.
/deploy/observability/secrets/*
!/deploy/observability/secrets/.gitkeep

# docs/plan/49 K3: mTLS CA + per-service leaf certs generated locally by
# `make certs` (cmd/certgen) — private keys, never committed, mirrors the
# observability-secret pattern above.
/deploy/certs/*
!/deploy/certs/.gitkeep

# docs/plan/50 K3/K5: pgBackRest repository passphrase and the seev_backup
# role password generated locally by `make backup-secret` — never
# committed, mirrors the observability-secret pattern above. The backup
# repository itself (encrypted physical backups + WAL) is host-path data,
# not something a machine's checkout should ever carry.
/deploy/backup/secrets/*
!/deploy/backup/secrets/.gitkeep
/deploy/backup/repo/*
!/deploy/backup/repo/.gitkeep
/deploy/backup/manifests/*
!/deploy/backup/manifests/.gitkeep

# Editor/IDE
# .idea/
# .vscode/
