{
  "uid": "seev-money-flow",
  "title": "Seev / Money Flow",
  "description": "Cross-service view of the money-moving pipeline: posting, outbox, integrity verifier, payout backlog, vendor health, and the RabbitMQ transport between them (docs/roadmap/archive/43 K7).",
  "tags": [
    "seev",
    "observability",
    "money"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Ledger posting",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "Postings by type/status",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "seev-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 8
      },
      "description": "",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "seev-prometheus"
          },
          "expr": "sum(rate(ledger_transactions_total[5m])) by (type, status)",
          "refId": "A",
          "legendFormat": "{{type}} {{status}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Posting error ratio",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "seev-prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 8,
        "h": 8
      },
      "description": "",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "seev-prometheus"
          },
          "expr": "sum(rate(ledger_transactions_total{status=\"error\"}[5m])) / sum(rate(ledger_transactions_total[5m]))",
          "refId": "A",
          "legendFormat": "error ratio"
        }
      ]
    },
    {
      "id": 4,
      "title": "Posting duration (p50/p95/p99)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "seev-prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 8,
        "h": 8
      },
      "description": "",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "seev-prometheus"
          },
          "expr": "histogram_quantile(0.50, sum(rate(ledger_post_duration_seconds_bucket[5m])) by (le))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "seev-prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(ledger_post_duration_seconds_bucket[5m])) by (le))",
          "refId": "B",
          "legendFormat": "p95"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "seev-prometheus"
          },
          "expr": "histogram_quantile(0.99, sum(rate(ledger_post_duration_seconds_bucket[5m])) by (le))",
          "refId": "C",
          "legendFormat": "p99"
        }
      ]
    },
