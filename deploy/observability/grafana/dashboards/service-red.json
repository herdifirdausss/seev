{
  "uid": "seev-service-red",
  "title": "Seev / Service RED",
  "description": "Per-service HTTP+gRPC RED metrics, Go runtime, and correlated logs (docs/plan/43 K7). Select a service with the job variable.",
  "tags": [
    "seev",
    "observability"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "seev-prometheus"
        },
        "query": {
          "query": "label_values(up, job)",
          "refId": "jobVariable"
        },
        "current": {
          "selected": true,
          "text": "gateway-service",
          "value": "gateway-service"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP RED",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "HTTP request rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "seev-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 8
      },
      "description": "",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "seev-prometheus"
          },
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"$job\"}[5m])) by (route, status_code)",
          "refId": "A",
          "legendFormat": "{{route}} {{status_code}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP error rate (5xx)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "seev-prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 8,
        "h": 8
      },
      "description": "",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "seev-prometheus"
          },
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"$job\", status_code=~\"5..\"}[5m])) by (route)",
          "refId": "A",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP latency (p50/p95/p99)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "seev-prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 8,
        "h": 8
      },
      "description": "",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "seev-prometheus"
          },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{job=\"$job\"}[5m])) by (le))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "seev-prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=\"$job\"}[5m])) by (le))",
          "refId": "B",
          "legendFormat": "p95"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "seev-prometheus"
          },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{job=\"$job\"}[5m])) by (le))",
          "refId": "C",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 5,
      "title": "gRPC RED",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
